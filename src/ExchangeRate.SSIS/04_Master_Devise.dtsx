          Id="c75695ad-377b-4b59-9c6e-8a38fb4a351f"
          TopLeft="673,2" />
        <AnnotationLayout
          Text="Déterminer la dernière date connue dans l'historique des devises pour déterminer une plage de mise à jour.&#xA;"
