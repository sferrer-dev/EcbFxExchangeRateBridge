    <DTS:Executable
      DTS:refId="Package\SQL_CurrencyExists"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tâche d'exécution de requêtes SQL"
      DTS:DTSID="{2BFAF191-90EA-49F9-BDD0-3647127AA2CB}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_CurrencyExists"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{FCE8F177-2F0E-4523-92E9-DAA8D3404395}"
          SQLTask:SqlStatementSource="SELECT CASE &#xA;         WHEN EXISTS (&#xA;           SELECT 1&#xA;           FROM dbo.exchange_rates_daily&#xA;           WHERE series_key = ?&#xA;         )&#xA;         THEN 1 &#xA;         ELSE 0 &#xA;       END AS currency_exists;"
          SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ResultBinding
            SQLTask:ResultName="currency_exists"
            SQLTask:DtsVariableName="User::CurrencyExists" />
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="0"
            SQLTask:DtsVariableName="$Package::pSeriesKey"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="130"
            SQLTask:ParameterSize="-1" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
