        <AnnotationLayout
          Text="Décision exécution snapshot mensuel :&#xA;&#xA;Calcule DoRunTariffMonthly :&#xA; 1 si table vide (bootstrap)&#xA; 1 si dernier jour du mois ET snapshot du mois absent&#xA; 0 sinon&#xA;&#xA;Objectif : garantir un unique snapshot mensuel et éviter toute exécution inutile."
          ParentId="Package"
