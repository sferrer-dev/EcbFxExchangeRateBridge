    <DTS:Executable
      DTS:refId="Package\SQL_Check_TariffMonthly_RunCondition"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{3508417E-2F3A-4455-8E9A-2BA2A891077F}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_Check_TariffMonthly_RunCondition"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{FCE8F177-2F0E-4523-92E9-DAA8D3404395}"
          SQLTask:SqlStatementSource="DECLARE @Today date = CAST(GETDATE() AS date);&#xA;-- “snapshot du mois courant” = dernier jour du mois (ex: 2026-02-28)&#xA;DECLARE @AsOfMonth date = EOMONTH(@Today);&#xA;&#xA;SELECT&#xA;    CASE&#xA;        WHEN NOT EXISTS (SELECT 1 FROM dbo.exchange_rates_tariff_monthly) THEN 1&#xA;        WHEN @Today &lt;&gt; @AsOfMonth THEN 0&#xA;        WHEN NOT EXISTS (&#xA;            SELECT 1&#xA;            FROM dbo.exchange_rates_tariff_monthly&#xA;            WHERE asof_date = @AsOfMonth&#xA;        ) THEN 1&#xA;        ELSE 0&#xA;    END &#xA;    AS dorun_tariff_monthly"
          SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ResultBinding
            SQLTask:ResultName="0"
            SQLTask:DtsVariableName="User::DoRunTariffMonthly" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
