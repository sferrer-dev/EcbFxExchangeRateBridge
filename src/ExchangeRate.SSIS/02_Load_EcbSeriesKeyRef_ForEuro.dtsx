    <DTS:Executable
      DTS:refId="Package\SQL_Check_SeriesRef_Exists"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{729b7db7-1fdf-4d83-b23d-88af300d5527}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_Check_SeriesRef_Exists"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:LoggingOptions
        DTS:FilterKind="0"
        DTS:LoggingMode="2" />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{FCE8F177-2F0E-4523-92E9-DAA8D3404395}"
          SQLTask:SqlStatementSource="SELECT&#xA;    CAST(&#xA;        CASE &#xA;            WHEN EXISTS (SELECT 1 FROM dbo.exchange_currency_series_ref)&#xA;            THEN 1 &#xA;            ELSE 0 &#xA;        END&#xA;    AS bit) AS series_exist;"
          SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ResultBinding
            SQLTask:ResultName="series_exist"
            SQLTask:DtsVariableName="User::SeriesExist" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
