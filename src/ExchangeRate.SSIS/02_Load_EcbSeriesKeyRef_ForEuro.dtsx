          <ProjectItem
            Name="ScriptMain.cs"
            Encoding="UTF8"><![CDATA[#region Namespaces
using System;
#endregion

namespace ST_77cc94c7503c4103b84af64a079f9d1d
{

    // Point d'entrée obligatoire pour une Script Task SSIS
    [Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
    public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
    {
        /// <summary>
        /// Méthode principale appelée par SSIS.
        /// IMPORTANT : en Script Task, Main() ne peut pas être async.
        /// On exécute donc le code asynchrone via GetAwaiter().GetResult().
        /// </summary>
        public void Main()
        {
            try
            {
                string url = Convert.ToString(Dts.Variables["User::Url"].Value);
                string downloadPath = Convert.ToString(Dts.Variables["User::DownloadPath"].Value);

                var downloader = new EcbHttpDownloader();

                LogInformation("Download ECB CSV", "Début du téléchargement : " + url);

                downloader.DownloadAsync(url, downloadPath).GetAwaiter().GetResult();

                // Si tout s'est bien passé, on marque la tâche comme réussie
                Dts.TaskResult = (int)ScriptResults.Success;
            }
            catch (Exception ex)
            {
                // En cas d'erreur bloquante, on loggue une erreur SSIS
                // FireError => message rouge dans les logs + exploitation possible en prod
                Dts.Events.FireError(
                    0,
                    "Download ECB CSV",
                    ex.Message,
                    string.Empty,
                    0);

                // On force l'échec de la Script Task
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        /// <summary>
        /// Log une information dans les logs SSIS.
        /// </summary>
        private void LogInformation(string title, string message)
        {
            bool fireAgain = false;

            Dts.Events.FireInformation(
                0,              // InformationCode
                title,          // SubComponent
                message,        // Description
                string.Empty,   // HelpFile
                0,              // HelpContext
                ref fireAgain
            );
        }
        #region ScriptResults declaration
        /// <summary>
        /// Enum standard généré par SSIS
        /// pour définir le résultat de la Script Task
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion
    }
}]]></ProjectItem>
