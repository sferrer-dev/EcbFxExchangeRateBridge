          <ProjectItem
            Name="ScriptMain.cs"
            Encoding="UTF8"><![CDATA[#region Namespaces
using System;
using System.IO;
using System.Net;
#endregion

namespace ST_a4c0d7d5ce5e4e2598bbfe2029582984
{
    /// <summary>
    ///  Script Task SSIS
    ///  Objectif : télécharger la codelist des devises publiée par la BCE
    ///  Source : API ECB (SDMX XML)
    ///  Cible  : fichier XML local utilisé par le flux d'intégration
    /// </summary>
    [Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
    public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
    {
        public void Main()
        {
            // URL de l'endpoint ECB retournant la codelist des devises (format XML SDMX)
            string url = (string)Dts.Variables["$Project::pEcbCurrencyCodelistApiUrl"].Value;

            // Chemin complet du fichier XML de sortie (dossier + nom de fichier)
            string filePath = (string)Dts.Variables["User::XmlTargetFilePath"].Value;

            try
            {
                /*
                    Garantit l'existence du dossier cible.
                    Utile lors de la première exécution ou après un nettoyage manuel.
                */
                string dir = Path.GetDirectoryName(filePath);
                if (!Directory.Exists(dir))
                    Directory.CreateDirectory(dir);

                /*
                    Force protocole TLS.
                    Nécessaire dans la plupart des environnements pour les appels HTTPS externes.
                */
                ServicePointManager.SecurityProtocol = SecurityProtocolType.Tls12;

                /*
                    Cr�ation de la requête HTTP GET vers l'API publique de la BCE.
                    Le header "Accept" précise que l'on attend une réponse XML.
                */
                var request = (HttpWebRequest)WebRequest.Create(url);
                request.Method = "GET";
                request.Accept = "application/xml";

                /*
                    Envoi de la requête HTTP et récupération de la réponse.
                    Une exception est levée si le code HTTP n'est pas 200 (OK).
                */
                using (var response = (HttpWebResponse)request.GetResponse())
                {
                    if (response.StatusCode != HttpStatusCode.OK)
                        throw new Exception(
                            "HTTP " + (int)response.StatusCode + " - " + response.StatusDescription
                        );

                    /*
                        Copie du flux de réponse HTTP directement dans le fichier XML cible.
                        Le fichier est écrasé à chaque exécution du package SSIS.
                    */
                    using (var stream = response.GetResponseStream())
                    using (var file = new FileStream(filePath, FileMode.Create, FileAccess.Write, FileShare.None))
                    {
                        stream.CopyTo(file);
                    }
                }

                // Message d'information visible dans les logs SSIS (exécution réussie)
                bool fireAgain = false;

                Dts.Events.FireInformation(
                    0,
                    "ECB Download",
                    "Fichier XML écrit : " + filePath,
                    "",
                    0,
                    ref fireAgain
                );

                // Indique à SSIS que la tâche s'est terminée avec succés
                Dts.TaskResult = (int)ScriptResults.Success;
            }
            catch (Exception ex)
            {
                /*
                    Gestion des erreurs :
                    - erreur réseau
                    - problème TLS
                    - problème d'accés disque
                    - réponse HTTP non conforme
                */
                Dts.Events.FireError(
                    0,
                    "ECB Download",
                    ex.ToString(),
                    "",
                    0
                );

                // Indique à SSIS que la tâche a échoué
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        #region ScriptResults declaration
        /// <summary>
        /// This enum provides a convenient shorthand within the scope of this class for setting the
        /// result of the script.
        /// 
        /// This code was generated automatically.
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion

    }
}]]></ProjectItem>
