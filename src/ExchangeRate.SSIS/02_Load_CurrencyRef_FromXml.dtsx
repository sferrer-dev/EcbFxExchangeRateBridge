      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{FCE8F177-2F0E-4523-92E9-DAA8D3404395}"
          SQLTask:SqlStatementSource="SELECT&#xA;    CAST(&#xA;        CASE &#xA;            WHEN EXISTS (SELECT 1 FROM dbo.currency_ref)&#xA;            THEN 1 &#xA;            ELSE 0 &#xA;        END&#xA;    AS bit) AS currencies_exist&#xA;"
          SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ResultBinding
            SQLTask:ResultName="currencies_exist"
            SQLTask:DtsVariableName="User::CurrenciesExist" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
