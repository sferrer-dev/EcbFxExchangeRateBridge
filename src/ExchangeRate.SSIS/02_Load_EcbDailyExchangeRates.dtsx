      DTS:Expression="LEN(TRIM(@[$Project::pEndPeriodOverride])) &gt; 0&#xA;? @[$Project::pEndPeriodOverride]&#xA;: (DT_WSTR,4) YEAR(GETDATE())&#xA;+ &quot;-&quot; +&#xA;RIGHT(&quot;0&quot; + (DT_WSTR,2) MONTH(GETDATE()), 2)&#xA;+ &quot;-&quot; +&#xA;RIGHT(&quot;0&quot; + (DT_WSTR,2) DAY(GETDATE()), 2)"
