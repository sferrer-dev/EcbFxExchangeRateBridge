              <ProjectItem
                Name="ScriptMain.cs"
                Encoding="UTF8"><![CDATA[#region Namespaces
using Microsoft.SqlServer.Dts.Runtime;
using System;
using System.IO;
using System.Net;
using System.Net.Http;
using System.Net.Http.Headers;
using System.Threading.Tasks;
#endregion

namespace ST_5d5548fdb18d473b8cbd6dd4e0c4983e
{

    // Point d’entrée obligatoire pour une Script Task SSIS
    [Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
    public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
    {
        /// <summary>
        /// Méthode principale appelée par SSIS.
        /// IMPORTANT : en Script Task, Main() ne peut pas être async.
        /// On exécute donc le code asynchrone via GetAwaiter().GetResult().
        /// </summary>
        public void Main()
        {
            try
            {
                // Appel synchrone d’une méthode async (pattern imposé par VSTA)
                DownloadCsvAsync().GetAwaiter().GetResult();

                // Si tout s’est bien passé, on marque la tâche comme réussie
                Dts.TaskResult = (int)ScriptResults.Success;
            }
            catch (Exception ex)
            {
                // En cas d’erreur bloquante, on loggue une erreur SSIS
                // FireError => message rouge dans les logs + exploitation possible en prod
                Dts.Events.FireError(
                    0,
                    "Download ECB CSV",
                    ex.Message,
                    string.Empty,
                    0);

                // On force l’échec de la Script Task
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }
        /// <summary>
        /// Télécharge un fichier CSV via HTTP/HTTPS et l’enregistre sur le disque.
        /// Méthode asynchrone pour éviter les blocages réseau.
        /// </summary>
        private async System.Threading.Tasks.Task DownloadCsvAsync()
        {
            // --- Sécurisation TLS ---
            // SSIS / VSTA s’exécute sous .NET Framework.
            // Par défaut, certaines versions n’utilisent pas TLS 1.2,
            // ce qui provoque des erreurs SSL/TLS avec des serveurs modernes.
            ServicePointManager.SecurityProtocol = SecurityProtocolType.Tls12;

            // Désactive "Expect: 100-Continue" pour éviter certains problèmes proxy
            ServicePointManager.Expect100Continue = false;

            // Récupération des variables SSIS
            // Bonnes pratiques : le chemin et l’URL sont construits dans le package,
            // pas dans le code C#
            string url = Convert.ToString(Dts.Variables["User::Url"].Value);
            string downloadPath = Convert.ToString(Dts.Variables["User::DownloadPath"].Value);

            // Validation des entrées (fail fast)
            if (string.IsNullOrWhiteSpace(url))
                throw new ArgumentException("La variable User::Url  est vide.");

            if (string.IsNullOrWhiteSpace(downloadPath))
                throw new ArgumentException("La variable User::DownloadPath est vide.");

            // Création du dossier cible si nécessaire
            string dir = Path.GetDirectoryName(downloadPath);
            if (!string.IsNullOrWhiteSpace(dir) && !Directory.Exists(dir))
                Directory.CreateDirectory(dir);

            // HttpClient : utilisé pour effectuer l’appel HTTP
            // Dans un Script Task, l’instance peut être locale
            using (var http = new HttpClient())
            {
                // Timeout explicite pour éviter un blocage infini
                http.Timeout = TimeSpan.FromSeconds(60);

                // Configuration des en-têtes HTTP
                // L’ECB renvoie généralement du text/csv ou text/plain
                http.DefaultRequestHeaders.Accept.Clear();
                http.DefaultRequestHeaders.Accept.Add(new MediaTypeWithQualityHeaderValue("text/csv"));
                http.DefaultRequestHeaders.Accept.Add(new MediaTypeWithQualityHeaderValue("text/plain"));
                // User-Agent explicite (bonne pratique côté serveurs)
                http.DefaultRequestHeaders.UserAgent.ParseAdd("SSIS-ScriptTask/1.0");

                // Appel HTTP en mode streaming :
                // on ne charge pas tout le fichier en mémoire
                using (HttpResponseMessage response = await http.GetAsync(url, HttpCompletionOption.ResponseHeadersRead).ConfigureAwait(false))
                {
                    // Si le serveur renvoie un code HTTP != 200
                    if (!response.IsSuccessStatusCode)
                    {
                        // Lecture d’un extrait de la réponse pour le diagnostic
                        string bodySnippet = await SafeReadSnippetAsync(response).ConfigureAwait(false);

                        throw new HttpRequestException(
                            "HTTP " + (int)response.StatusCode + " (" + response.ReasonPhrase + "). " +
                            "URL=" + url + ". Réponse (extrait)=" + bodySnippet);
                    }

                    // Lecture du flux HTTP et écriture directe sur disque
                    using (Stream contentStream = await response.Content.ReadAsStreamAsync().ConfigureAwait(false))
                    using (FileStream fileStream = new FileStream(downloadPath, FileMode.Create, FileAccess.Write, FileShare.None))
                    {
                        await contentStream.CopyToAsync(fileStream).ConfigureAwait(false);
                    }
                }
            }

            // Log d’information SSIS en cas de succès
            LogInformation("Download ECB CSV", "CSV téléchargé avec succès : " + downloadPath);
        }
        /// <summary>
        /// Lit un extrait limité de la réponse HTTP
        /// pour éviter de logguer des payloads volumineux.
        /// </summary>
        private static async Task<string> SafeReadSnippetAsync(HttpResponseMessage response)
        {
            try
            {
                string content = await response.Content.ReadAsStringAsync().ConfigureAwait(false);
                if (string.IsNullOrEmpty(content)) return "<vide>";
                return content.Length <= 300 ? content : content.Substring(0, 300) + "...";
            }
            catch
            {
                // En cas d’erreur de lecture (timeout, stream fermé, etc.)
                return "<impossible de lire le contenu>";
            }
        }
        /// <summary>
        /// Log une information dans les logs SSIS.
        /// </summary>
        private void LogInformation(string title, string message)
        {
            bool fireAgain = false;

            Dts.Events.FireInformation(
                0,              // InformationCode
                title,          // SubComponent
                message,        // Description
                string.Empty,   // HelpFile
                0,              // HelpContext
                ref fireAgain
            );
        }
        #region ScriptResults declaration
        /// <summary>
        /// Enum standard généré par SSIS
        /// pour définir le résultat de la Script Task
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion
    }

}]]></ProjectItem>
