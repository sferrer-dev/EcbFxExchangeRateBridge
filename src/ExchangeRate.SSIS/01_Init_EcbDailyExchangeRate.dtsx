          <ProjectItem
            Name="ScriptMain.cs"
            Encoding="UTF8"><![CDATA[#region Namespaces
using Microsoft.SqlServer.Dts.Runtime;
using System;
using System.Data;
using System.Windows.Forms;
#endregion

namespace ST_782bf9b58eac457c87da59adfac53caa
{

    [Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
    public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
    {
        /// <summary>
        /// Le point d'entrée d'exécution du script
        /// </summary>
        public void Main()
        {
            try
            {
                // 1) Construire un DataTable (ADO) avec une colonne "FolderPath"
                var dt = new DataTable("Folders");
                dt.Columns.Add("FolderPath", typeof(string));

                // 2) Lire les paramétres projet
                string root = (string)Dts.Variables["$Project::pRootFolder"].Value;
                string data = (string)Dts.Variables["$Project::pDataRoot"].Value;
                string inF = (string)Dts.Variables["$Project::pInFolder"].Value;
                string outF = (string)Dts.Variables["$Project::pOutFolder"].Value;
                string arch = (string)Dts.Variables["$Project::pArchiveFolder"].Value;
                string logs = (string)Dts.Variables["$Project::pLogsFolder"].Value;
                string cfg = (string)Dts.Variables["$Project::pConfigFolder"].Value;

                // 3) Ajouter les dossiers à créer (ordre logique parent -> enfants)
                AddFolder(dt, root);
                AddFolder(dt, data);
                AddFolder(dt, inF);
                AddFolder(dt, outF);
                AddFolder(dt, arch);
                AddFolder(dt, logs);
                AddFolder(dt, cfg);

                // 4) Affecter à la variable Object pour le Foreach ADO Enumerator
                Dts.Variables["User::FoldersToCreate"].Value = dt;
                Dts.TaskResult = (int)ScriptResults.Success;
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "ST - Build Folder List", ex.ToString(), "", 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }
        /// <summary>
        /// Ajoute un dossier au DataTable s'il n'est pas vide et n'existe pas d�j�
        /// </summary>
        private void AddFolder(DataTable dt, string path)
        {
            if (string.IsNullOrWhiteSpace(path))
                return;
            // Normalisation minimale : trimming (sans casser les backslashes)
            string normalized = path.Trim();
            // évite les doublons si param�tres identiques
            foreach (DataRow row in dt.Rows)
            {
                if (string.Equals((string)row["FolderPath"], normalized, StringComparison.OrdinalIgnoreCase))
                    return;
            }
            dt.Rows.Add(normalized);
        }

        #region ScriptResults declaration
        /// <summary>
        /// This enum provides a convenient shorthand within the scope of this class for setting the
        /// result of the script.
        /// 
        /// This code was generated automatically.
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion
    }

}]]></ProjectItem>
