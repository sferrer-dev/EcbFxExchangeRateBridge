          SQLTask:SqlStatementSource="SELECT COUNT(1) AS ErrorCount&#xA;FROM SalesMgmtDB.dbo.fn_Audit_EcbVsDevisesHisto(?, ?)&#xA;WHERE Status &lt;&gt; 'OK';"
