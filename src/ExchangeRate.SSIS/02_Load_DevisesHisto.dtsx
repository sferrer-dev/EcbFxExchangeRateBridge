      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{8EC4B052-60A1-4AC5-8735-C10FDE370140}"
          SQLTask:SqlStatementSource="SELECT&#xA;    CAST(&#xA;        CASE &#xA;            WHEN EXISTS (SELECT 1 FROM SalesMgmtDB.dbo.DEVISES_HISTO)&#xA;            THEN 1 &#xA;            ELSE 0 &#xA;        END&#xA;    AS bit) AS devises_exist;"
          SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ResultBinding
            SQLTask:ResultName="devises_exist"
            SQLTask:DtsVariableName="User::DevisesExist" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
