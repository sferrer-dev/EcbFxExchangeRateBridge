          TopLeft="71.6153846153846,73.7692307692308" />
        <AnnotationLayout
          Text="Objectif du package&#xA;Mettre à jour les taux de change dans la table des devises à partir de ceux qui ont été synchronisés dans la table de l'historique des devises.&#xA;&#xA;Principe de fonctionnement&#xA;1. Vérifier qu'il n'y a pas d'anomalie et que l'historique des devises est bien synchronisé.&#xA;2. Mettre à jour les taux de change des devises suivies depuis l'historique.&#xA;3. Loguer le nombre de devises mises à jour."
          ParentId="Package"
          FontInfo="{assembly:Null}"
          Size="766,136"
          Id="340c3c97-bfe0-4474-a6c6-b83f0b37e749"
          TopLeft="581.153846153847,6.07692307692308" />
        <AnnotationLayout
